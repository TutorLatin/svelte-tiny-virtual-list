{
	"name": "@tutorlatin/svelte-tiny-virtual-list",
	"version": "3.0.20",
	"description": "A tiny but mighty list virtualization component for svelte, with zero dependencies 💪",
	"homepage": "https://svelte-tiny-virtual-list.jonasgeiler.com",
	"bugs": "https://github.com/tutorlatin/svelte-tiny-virtual-list/issues",
	"funding": "https://github.com/sponsors/jonasgeiler",
	"license": "MIT",
	"author": "Jonas Geiler <npm@jonasgeiler.com> (https://jonasgeiler.com)",
	"contributors": [
		"TutorLatin"
	],
	"repository": "github:TutorLatin/svelte-tiny-virtual-list",
	"scripts": {
		"prepare": "git config core.hooksPath .githooks && (svelte-kit sync || echo '')",
		"dev": "vite dev",
		"start": "pnpm run dev",
		"build": "vite build && pnpm run prepack",
		"preview": "vite preview",
		"prepack": "svelte-kit sync && svelte-package && publint",
		"check": "pnpm run '/^check:.*/'",
		"check:biome": "biome check",
		"check:eslint": "eslint .",
		"check:prettier": "prettier --check .",
		"check:vitest": "vitest run",
		"check:playwright": "playwright test",
		"check:svelte": "svelte-kit sync && (svelte-check --tsconfig ./jsconfig.json || echo 'Fix svelte-check errors!')",
		"fix": "pnpm run fix:biome && pnpm run fix:eslint && pnpm run fix:prettier",
		"fix:biome": "biome check --fix",
		"fix:eslint": "eslint --fix .",
		"fix:prettier": "prettier --write .",
		"fix-unsafe": "pnpm run fix-unsafe:biome",
		"fix-unsafe:biome": "biome check --fix --unsafe"
	},
	"engines": {
		"node": ">=20.17.0"
	},
	"packageManager": "pnpm@10.12.4+sha512.5ea8b0deed94ed68691c9bad4c955492705c5eeb8a87ef86bc62c74a26b037b08ff9570f108b2e4dbd1dd1a9186fea925e527f141c648e85af45631074680184",
	"peerDependencies": {
		"svelte": "^5.0.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.15",
		"@eslint/compat": "^2.1.0",
		"@eslint/js": "^10.0.1",
		"@playwright/test": "^1.60.0",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.61.1",
		"@sveltejs/package": "^2.5.7",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@vitest/browser": "^4.1.7",
		"eslint": "^10.4.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.17.1",
		"globals": "^17.6.0",
		"lint-staged": "^17.0.5",
		"marked": "^18.0.4",
		"marked-base-url": "^1.1.9",
		"marked-gfm-heading-id": "^4.1.4",
		"playwright": "^1.53.0",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^4.0.1",
		"publint": "^0.3.21",
		"svelte": "^5.55.9",
		"svelte-check": "^4.4.8",
		"svelte-infinite-loading": "^1.4.0",
		"typescript": "^6.0.3",
		"vite": "^8.0.14",
		"vitest": "^4.0.15",
		"vitest-browser-svelte": "^2.1.1"
	},
	"files": [
		"dist",
		"!dist/**/*.test.*",
		"!dist/**/*.spec.*"
	],
	"sideEffects": [
		"**/*.css"
	],
	"type": "module",
	"svelte": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"svelte": "./dist/index.js"
		}
	},
	"keywords": [
		"svelte",
		"virtual",
		"list",
		"scroll",
		"infinite",
		"loading",
		"component",
		"plugin",
		"svelte-components"
	]
}
